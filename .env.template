# MobiAgent 环境配置模板
# 复制此文件为 .env 并填入您的 API Key

# ==================== LLM API 配置 ====================
# Qwen (通义千问) API Key
QWEN_API_KEY=your_qwen_api_key_here

# ChatGLM (智谱AI) API Key
CHATGLM_API_KEY=your_chatglm_api_key_here

# ==================== ForensiVision OCR API 配置 ====================
# OCR API Key (用于文字识别)
OCR_API_KEY=your_ocr_api_key_here
OCR_SECRET_KEY=your_ocr_secret_key_here

# ==================== 其他配置 ====================
# 数据目录
DATA_DIR=./data

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ==================== 语义匹配配置 ====================
# 是否启用语义匹配器 (true/false)
# 启用后会先用 BGE 模型快速匹配，失败时才调用 LLM
SEMANTIC_MATCHER_ENABLED=true

# BGE 模型路径
# SEMANTIC_MATCHER_MODEL_PATH=/root/MobiAgent/external/models/bge-small-zh-v1.5

# 语义匹配阈值 (0.0-1.0)
# 高于此值直接返回，不调用 LLM
SEMANTIC_MATCHER_THRESHOLD=0.6

# 语义匹配缓存大小（屏幕数量）
SEMANTIC_MATCHER_CACHE_SIZE=5

# 语义匹配运行设备 (cpu/cuda)
SEMANTIC_MATCHER_DEVICE=cpu

# ==================== RAG 模板匹配配置 ====================
# 是否启用 RAG 模板匹配 (true/false)
# 启用后会先检索相似任务模板作为 LLM Few-Shot 示例
RAG_ENABLED=true

# RAG BGE 模型路径 (bge-large-zh-v1.5)
# RAG_MODEL_PATH=/root/MobiAgent/external/models/bge-large-zh-v1.5

# RAG 模板目录
# RAG_TEMPLATES_DIR=/root/MobiAgent/external/rag_templates

# RAG 匹配阈值 (0.0-1.0)
# 高于此值的模板会作为参考示例提供给 LLM
RAG_THRESHOLD=0.75

# RAG 返回前 K 个模板 (1-5)
RAG_TOP_K=3

# RAG 运行设备 (cpu/cuda)
RAG_DEVICE=cpu

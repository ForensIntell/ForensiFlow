# MobiAgent 环境配置模板
# 复制此文件为 .env 并填入您的 API Key

# ==================== LLM API 配置 ====================
# Qwen (通义千问) API Key
QWEN_API_KEY=your_qwen_api_key_here

# ChatGLM (智谱AI) API Key
CHATGLM_API_KEY=your_chatglm_api_key_here

# ==================== VisionTasker OCR API 配置 ====================
# OCR API Key (用于文字识别)
OCR_API_KEY=your_ocr_api_key_here
OCR_SECRET_KEY=your_ocr_secret_key_here

# ==================== 其他配置 ====================
# 数据目录
DATA_DIR=./data

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
